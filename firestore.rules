rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // User profile matching rules (Isolated PII)
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() 
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 100;
      allow update: if isSignedIn() 
                    && request.auth.uid == userId
                    && request.resource.data.uid == userId
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 100
                    && request.resource.data.uid == resource.data.uid;
      allow delete: if false;
    }

    // Projects / Categories matching rules
    match /projects/{projectId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && isValidId(projectId)
                    && request.resource.data.id == projectId
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.color is string
                    && request.resource.data.color.size() <= 30;
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.id == projectId
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 40
                    && request.resource.data.color is string
                    && request.resource.data.color.size() <= 30
                    && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Tasks matching rules
    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
                    && isValidId(taskId)
                    && request.resource.data.id == taskId
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.completed is bool
                    && request.resource.data.priority in ['low', 'medium', 'high']
                    && request.resource.data.dueDate is string
                    && request.resource.data.dueDate.size() <= 50;
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.id == taskId
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.completed is bool
                    && request.resource.data.priority in ['low', 'medium', 'high']
                    && request.resource.data.dueDate is string
                    && request.resource.data.dueDate.size() <= 50
                    && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
